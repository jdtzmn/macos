#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: remote [--org ORG] [--sprite NAME] <command> [args]

Commands:
  create           Create the Sprite and configure it from the macos repo
  rebuild          Update the macos bootstrap repo and re-apply the config
  exec -- CMD...   Run a command in the Sprite home directory
  console          Open an interactive shell in the Sprite home directory
  ssh              Open an SSH session through sprite proxy with agent forwarding
  proxy ...        Forward ports with sprite proxy
  doctor           Show remote environment status
  destroy ...      Destroy the Sprite
EOF
}

die() {
  printf 'remote: %s\n' "$*" >&2
  exit 1
}

warn() {
  printf 'remote: %s\n' "$*" >&2
}

log() {
  printf 'remote: %s\n' "$*"
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

sanitize_name() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9-' '-'
}

canonical_git_url() {
  case "$1" in
    git@github.com:*)
      printf 'https://github.com/%s\n' "${1#git@github.com:}"
      ;;
    ssh://git@github.com/*)
      printf 'https://github.com/%s\n' "${1#ssh://git@github.com/}"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

script_path="${BASH_SOURCE[0]}"
while [ -L "$script_path" ]; do
  script_dir=$(cd -P "$(dirname "$script_path")" && pwd)
  script_path=$(readlink "$script_path")
  case "$script_path" in
    /*) ;;
    *) script_path="$script_dir/$script_path" ;;
  esac
done

script_dir=$(cd -P "$(dirname "$script_path")" && pwd)
bootstrap_local_repo_root=$(cd "$script_dir/../.." && pwd)
bootstrap_repo_url=$(git -C "$bootstrap_local_repo_root" remote get-url origin 2>/dev/null) || die "bootstrap macos repo must have an origin remote"
bootstrap_repo_url=$(canonical_git_url "$bootstrap_repo_url")
bootstrap_repo_dir="/home/sprite/.local/share/remote/macos"
remote_home_dir="/home/sprite"

workload_repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || die "must be run from a git repository"
workload_repo_name=$(basename "$workload_repo_root")
workload_repo_slug=$(sanitize_name "$workload_repo_name")
workload_identity=$(git -C "$workload_repo_root" remote get-url origin 2>/dev/null || printf '%s' "$workload_repo_root")
workload_hash=$(printf '%s' "$workload_identity" | git hash-object --stdin | cut -c1-6)

sprite_name="${REMOTE_SPRITE_NAME:-}"
org_name="${REMOTE_SPRITE_ORG:-}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    -o|--org)
      [ "$#" -ge 2 ] || die "missing value for $1"
      org_name="$2"
      shift 2
      ;;
    -s|--sprite)
      [ "$#" -ge 2 ] || die "missing value for $1"
      sprite_name="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

[ "$#" -gt 0 ] || {
  usage
  exit 1
}

subcommand="$1"
shift
ssh_pubkey_path=""

if [ -z "$sprite_name" ]; then
  sprite_name="${workload_repo_slug}-${workload_hash}"
fi

sprite_scope_args=(-s "$sprite_name")
sprite_org_args=()
if [ -n "$org_name" ]; then
  sprite_scope_args=(-o "$org_name" "${sprite_scope_args[@]}")
  sprite_org_args=(-o "$org_name")
fi

require_command git
require_command readlink
require_command sprite
require_command mktemp
require_command ssh
require_command lsof
require_command nc

sprite_exists() {
  local output

  output=$(sprite api "${sprite_org_args[@]}" /sprites 2>/dev/null || true)
  printf '%s' "$output" | grep -Eq '"name"[[:space:]]*:[[:space:]]*"'"$sprite_name"'"'
}

require_sprite() {
  sprite_exists || die "remote environment not created; run 'remote create' first"
}

run_remote_exec() {
  sprite exec "${sprite_scope_args[@]}" "$@"
}

sync_bootstrap_repo() {
  log "syncing bootstrap repo from origin/main"
  run_remote_exec --env "BOOTSTRAP_REPO_URL=$bootstrap_repo_url" -- bash -lc '
    set -euo pipefail
    repo_dir="$1"
    parent_dir=$(dirname "$repo_dir")
    temp_dir=$(mktemp -d)
    trap "rm -rf \"$temp_dir\"" EXIT
    mkdir -p "$parent_dir"
    git clone --depth 1 --branch main "$BOOTSTRAP_REPO_URL" "$temp_dir/repo"
    rm -rf "$repo_dir"
    mv "$temp_dir/repo" "$repo_dir"
  ' _ "$bootstrap_repo_dir"
}

apply_home() {
  log "applying sprite home-manager config"
  run_remote_exec -- bash -lc '
    set -euo pipefail
    repo_dir="$1"
    export PATH="$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:$PATH"
    export NIX_CONFIG="experimental-features = nix-command flakes"
    export USER="${USER:-sprite}"
    export LOGNAME="${LOGNAME:-$USER}"
    export SHELL="${SHELL:-/usr/bin/bash}"

    if ! command -v nix >/dev/null 2>&1; then
      curl -fsSL https://nixos.org/nix/install -o /tmp/nix-install.sh
      sh /tmp/nix-install.sh --no-daemon
      rm -f /tmp/nix-install.sh
      export PATH="$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:$PATH"
    fi

    if [ -f "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then
      . "$HOME/.nix-profile/etc/profile.d/nix.sh"
    fi

    REPO_DIR="$repo_dir" nix run home-manager -- switch -b backup --flake "$repo_dir#sprite" --impure
  ' _ "$bootstrap_repo_dir"
}

verify_remote() {
  log "verifying remote bootstrap state"
  run_remote_exec -- bash -lc '
    set -euo pipefail
    repo_dir="$1"
    test -f "$repo_dir/flake.nix"
    test -x "$HOME/.local/bin/remote"
    test -e "$HOME/.config/opencode"
  ' _ "$bootstrap_repo_dir"
}

run_rebuild() {
  sync_bootstrap_repo
  apply_home
  verify_remote
}

run_create() {
  sprite_exists && die "remote environment already exists; use 'remote rebuild' instead"
  log "creating sprite $sprite_name"
  sprite create "${sprite_org_args[@]}" --skip-console "$sprite_name"
  run_rebuild
  printf 'remote: created %s for %s\n' "$sprite_name" "$workload_repo_name"
}

resolve_pubkey() {
  local candidate

  if [ -n "${ssh_pubkey_path:-}" ]; then
    [ -f "$ssh_pubkey_path" ] || die "public key not found: $ssh_pubkey_path"
    printf '%s\n' "$ssh_pubkey_path"
    return
  fi

  for candidate in \
    "$HOME/.ssh/id_ed25519.pub" \
    "$HOME/.ssh/id_ecdsa.pub" \
    "$HOME/.ssh/id_rsa.pub"
  do
    if [ -f "$candidate" ]; then
      printf '%s\n' "$candidate"
      return
    fi
  done

  die "no public key found; pass --pubkey or create ~/.ssh/id_ed25519.pub"
}

find_free_ssh_port() {
  local port

  port=2201
  while lsof -nP -iTCP:"$port" >/dev/null 2>&1; do
    port=$((port + 1))
  done

  printf '%s\n' "$port"
}

ensure_remote_ssh() {
  local pubkey_file
  local pubkey_value

  pubkey_file=$(resolve_pubkey)
  pubkey_value=$(<"$pubkey_file")

  log "preparing ssh access with $(basename "$pubkey_file")"
  run_remote_exec --env "PUBKEY=$pubkey_value" -- bash -lc '
    set -euo pipefail

    if ! command -v sshd >/dev/null 2>&1; then
      sudo apt-get update
      sudo apt-get install -y openssh-server
    fi

    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
    touch "$HOME/.ssh/authorized_keys"
    chmod 600 "$HOME/.ssh/authorized_keys"
    if ! grep -Fqx "$PUBKEY" "$HOME/.ssh/authorized_keys"; then
      printf "%s\n" "$PUBKEY" >> "$HOME/.ssh/authorized_keys"
    fi

    sudo mkdir -p /run/sshd
    sudo sshd -t
    if command -v systemctl >/dev/null 2>&1; then
      sudo systemctl enable --now ssh >/dev/null 2>&1 || sudo systemctl enable --now sshd >/dev/null 2>&1 || sudo /usr/sbin/sshd
    else
      sudo service ssh start >/dev/null 2>&1 || sudo service sshd start >/dev/null 2>&1 || sudo /usr/sbin/sshd
    fi
  '
}

wait_for_proxy() {
  local port
  local attempts

  port="$1"
  attempts=0
  while [ "$attempts" -lt 50 ]; do
    if nc -z localhost "$port" >/dev/null 2>&1; then
      return 0
    fi
    attempts=$((attempts + 1))
    sleep 0.2
  done

  return 1
}

run_ssh() {
  local local_port
  local proxy_log
  local proxy_pid

  ensure_remote_ssh
  local_port=$(find_free_ssh_port)
  proxy_log=$(mktemp -t remote-ssh-proxy.XXXXXX.log)

  cleanup_proxy() {
    if [ -n "${proxy_pid:-}" ] && kill -0 "$proxy_pid" >/dev/null 2>&1; then
      kill "$proxy_pid" >/dev/null 2>&1 || true
      wait "$proxy_pid" >/dev/null 2>&1 || true
    fi
    rm -f "$proxy_log"
  }

  trap cleanup_proxy EXIT INT TERM

  log "starting ssh proxy on localhost:$local_port"
  sprite proxy "${sprite_scope_args[@]}" "$local_port:22" >"$proxy_log" 2>&1 &
  proxy_pid=$!

  if ! wait_for_proxy "$local_port"; then
    cat "$proxy_log" >&2 || true
    die "ssh proxy did not become ready on localhost:$local_port"
  fi

  log "connecting to $sprite_name over ssh"
  ssh -A -o StrictHostKeyChecking=accept-new -p "$local_port" sprite@localhost
}

show_doctor() {
  printf 'workload_repo: %s\n' "$workload_repo_root"
  printf 'workload_identity: %s\n' "$workload_identity"
  printf 'bootstrap_repo: %s\n' "$bootstrap_local_repo_root"
  printf 'bootstrap_url: %s\n' "$bootstrap_repo_url"
  printf 'bootstrap_remote: %s\n' "$bootstrap_repo_dir"
  printf 'sprite: %s\n' "$sprite_name"
  if [ -n "$org_name" ]; then
    printf 'org: %s\n' "$org_name"
  fi

  if ! sprite_exists; then
    printf 'status: missing\n'
    exit 0
  fi

  printf 'status: created\n'
  printf 'home: %s\n' "$remote_home_dir"

  if sha=$(run_remote_exec -- bash -lc 'set -euo pipefail; repo_dir="$1"; if [ -d "$repo_dir/.git" ]; then git -C "$repo_dir" rev-parse HEAD; fi' _ "$bootstrap_repo_dir" 2>/dev/null); then
    if [ -n "$sha" ]; then
      printf 'bootstrap_sha: %s\n' "$sha"
    fi
  fi

  if run_remote_exec -- bash -lc 'test -x "$HOME/.local/bin/remote" && test -e "$HOME/.config/opencode"' >/dev/null 2>&1; then
    printf 'config: applied\n'
  else
    printf 'config: unknown\n'
  fi
}

case "$subcommand" in
  create)
    run_create
    ;;
  rebuild)
    require_sprite
    run_rebuild
    printf 'remote: rebuilt %s from macos origin/main\n' "$sprite_name"
    ;;
  exec)
    require_sprite
    [ "$#" -gt 0 ] || die "missing command for exec"
    if [ "$1" = "--" ]; then
      shift
    fi
    [ "$#" -gt 0 ] || die "missing command for exec"
    run_remote_exec --dir "$remote_home_dir" "$@"
    ;;
  console)
    require_sprite
    run_remote_exec --tty -- bash -lc 'set -euo pipefail; cd "$1"; if command -v fish >/dev/null 2>&1; then exec fish; fi; exec bash' _ "$remote_home_dir"
    ;;
  ssh)
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --pubkey)
          [ "$#" -ge 2 ] || die "missing value for --pubkey"
          ssh_pubkey_path="$2"
          shift 2
          ;;
        *)
          die "unknown ssh option: $1"
          ;;
      esac
    done
    if ! sprite_exists; then
      log "sprite missing, creating it first"
      run_create
    fi
    run_ssh
    ;;
  proxy)
    require_sprite
    [ "$#" -gt 0 ] || die "missing ports for proxy"
    sprite proxy "${sprite_scope_args[@]}" "$@"
    ;;
  doctor)
    show_doctor
    ;;
  destroy)
    require_sprite
    sprite destroy "${sprite_scope_args[@]}" "$@"
    ;;
  *)
    usage
    die "unknown command: $subcommand"
    ;;
esac
