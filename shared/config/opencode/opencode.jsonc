{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["bunx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
    },
    "peekaboo": {
      "type": "local",
      "command": ["bunx", "-y", "@steipete/peekaboo", "mcp", "serve", "--transport", "stdio"],
      "enabled": true,
      "timeout": 30000,
    },
    "backgroundProcess": {
      "type": "local",
      "command": ["bunx", "--package", "github:jdtzmn/background-process-mcp#main", "bgpm"],
      "enabled": true,
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/readonly",
      "oauth": false,
      "headers": {
        "X-MCP-Tools": "search_pull_requests,pull_request_read,search_issues,issue_read",
        "X-MCP-Readonly": "true",
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}",
      },
      "enabled": true,
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true,
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
    },
  },
  "plugin": [
    "@0xsero/open-queue",
    "premind@git+https://github.com/jdtzmn/premind.git",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-delegated-access@git+https://github.com/jdtzmn/opencode-delegated-access.git",
    "opencode-mem",
  ],
  "instructions": [
    "~/.config/opencode/me.md",
    "https://raw.githubusercontent.com/jdtzmn/port/refs/heads/main/ONBOARD.md",
  ],
  "permission": {
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
    },
    "bash": {
      "*": "ask",
      "docker-compose *": "allow",
      "bun *": "allow",
      "bunx playwright *": "allow",
      "bun run playwright *": "allow",
      "bunx tsc": "allow",
      "bunx tsc *": "allow",
      "bunx eslint": "allow",
      "bunx eslint *": "allow",
      "bunx prettier --write": "allow",
      "bunx prettier --write *": "allow",
      "bunx vitest": "allow",
      "bunx vitest *": "allow",
      "uv run pytest": "allow",
      "uv run pytest *": "allow",
      "uv run ruff": "allow",
      "uv run ruff *": "allow",
      "make": "allow",
      "make *": "allow",
      "cd *": "allow",
      "cat *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "mkdir *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git log": "allow",
      "git log *": "allow",

      "git rev-parse": "allow",
      "git rev-parse *": "allow",
      "git stash": "allow",
      "git stash *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git fetch": "allow",
      "git fetch *": "allow",
      "git merge main": "allow",
      "sleep *": "allow",
      "echo *": "allow",
      "xcodebuild": "allow",
      "xcodebuild *": "allow",
      "bd *": "allow",
      "port": "allow",
      "port *": "allow",
      "docker ps *": "allow",
      "docker inspect *": "allow",
      "docker compose ps": "allow",
      "docker compose ps *": "allow",
      "docker logs *": "allow",
      "docker compose logs": "allow",
      "docker compose logs *": "allow",
      "docker compose config": "allow",
      "docker compose config *": "allow",
      "gh run view": "allow",
      "gh run view *": "allow",
      "gh run list": "allow",
      "gh run list *": "allow",
      "gh pr view": "allow",
      "gh pr view *": "allow",
      "gh pr list": "allow",
      "gh pr list *": "allow",
      "gh pr checks": "allow",
      "gh pr checks *": "allow",
      "gh issue view": "allow",
      "gh issue view *": "allow",
      "gh issue list": "allow",
      "gh issue list *": "allow",
      "gh repo view": "allow",
      "gh repo view *": "allow",
      "gh auth status": "allow",
      "gh auth status *": "allow",
      "date +%s": "allow",
      "date -u +%s": "allow",
    },
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow",
      "*.env.template": "allow",
    },
    "peekaboo_*": "ask",
  },
  "agent": {
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
    },
  },
}
