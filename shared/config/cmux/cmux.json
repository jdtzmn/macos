{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  // This file uses JSON with comments (JSONC).
  // Uncomment and edit any setting to make it file-managed.
  // Remove a setting to fall back to the value saved in Settings.
  // cmux creates this template on launch when ~/.config/cmux/cmux.json is missing.
  // Legacy settings.json files are read only as fallback for keys not present here.

  // ── Active overrides ───────────────────────────────────────────────
  // Commented blocks below show all available defaults for reference.

  "app": {
    "appearance": "dark",
    "iMessageMode": false,
    "newWorkspacePlacement": "end",
    "reorderOnNotification": false,
    "sendAnonymousTelemetry": false,
    "commandPaletteSearchesAllSurfaces": true
  },

  "terminal": {
    "showScrollBar": false,
    "autoResumeAgentSessions": true
  },

  "notifications": {
    // opencode plugin handles audio via terminal-notifier; avoid double-dinging.
    "sound": "none"
  },

  "browser": {
    "openTerminalLinksInCmuxBrowser": true,
    "interceptTerminalOpenCommandInCmuxBrowser": true,
    "hostsToOpenInEmbeddedBrowser": [
      "*.port",
      "*.stlabs"
    ],
    "insecureHttpHostsAllowedInEmbeddedBrowser": [
      "localhost",
      "*.localhost",
      "127.0.0.1",
      "::1",
      "0.0.0.0",
      "*.localtest.me",
      "*.port",
      "*.stlabs"
    ]
  },

  "workspaceColors": {
    "indicatorStyle": "washRail",
    "colors": {
      // Built-in cmux defaults (kept so existing workspace assignments survive)
      "Red": "#C0392B",
      "Crimson": "#922B21",
      "Orange": "#A04000",
      "Amber": "#7D6608",
      "Olive": "#4A5C18",
      "Green": "#196F3D",
      "Teal": "#006B6B",
      "Aqua": "#0E6B8C",
      "Blue": "#1565C0",
      "Navy": "#1A5276",
      "Indigo": "#283593",
      "Purple": "#6A1B9A",
      "Magenta": "#AD1457",
      "Rose": "#880E4F",
      "Brown": "#7B3F00",
      "Charcoal": "#3E4B5E",

      // Tokyo Night Moon — sourced from shared/config/opencode/themes/tokyonight-transparent.json
      "TokyoNight Blue":   "#82aaff",
      "TokyoNight Purple": "#c099ff",
      "TokyoNight Orange": "#ff966c",
      "TokyoNight Red":    "#ff757f",
      "TokyoNight Yellow": "#ffc777",
      "TokyoNight Green":  "#c3e88d",
      "TokyoNight Cyan":   "#86e1fc",
      "TokyoNight Muted":  "#828bb8"
    }
  },

  "sidebarAppearance": {
    "matchTerminalBackground": true
  },

  "shortcuts": {
    "bindings": {
      "prevSidebarTab": "cmd+shift+↑",
      "nextSidebarTab": "cmd+shift+↓"
    }
  },

